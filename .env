# Toggle between dummy data (true) and real backend API (false)
VITE_USE_DUMMY_API=false

# Base URL for the frontend to call (we use /api to route through the Vite proxy)
VITE_API_BASE_URL=/api

# The actual backend URL that the Vite proxy will forward requests to
VITE_PROXY_TARGET=https://mesh-backend-ob80.onrender.com
